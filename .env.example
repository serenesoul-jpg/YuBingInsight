# 数据库（Docker 与本机 API 同机部署时用 127.0.0.1）
DATABASE_URL="postgresql://yubing:yubing@127.0.0.1:5432/yubing_insight?schema=public"

# API（服务器上保持 3000；安全组放行该端口供本机微信工具联调）
PORT=3000
JWT_SECRET=yubing-dev-change-in-production

# 本机跑小程序、API 在远程服务器时，在本地 shell 设置（不要写进本文件提交）
# YUBING_API_BASE=http://你的服务器公网IP:3000

# 微信小程序（后续微信登录接入时填写）
WECHAT_APPID=""
WECHAT_SECRET=""
